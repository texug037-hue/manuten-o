# Copie este arquivo para ".env" (mesma pasta) e preencha com os valores do
# SEU projeto Firebase. O arquivo ".env" nunca deve ir para o GitHub — ele já
# está listado no .gitignore. Este arquivo (.env.example) pode ser commitado
# normalmente, pois não tem nenhum valor real.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional, mas recomendado: Firebase Console > App Check > reCAPTCHA v3
# Sem preencher, o app funciona normalmente e apenas fica sem essa camada extra.
VITE_RECAPTCHA_SITE_KEY=
