rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function myRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isAdmin() { return myRole() == 'administrador'; }

    // só permite os campos esperados num documento NOVO — bloqueia tentativas
    // de injetar campos extras/arbitrários (ex: role forjado na criação)
    function onlyFields(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    // documento único usado para decidir automaticamente quem é o primeiro
    // usuário do app (esse vira administrador). Crie-o manualmente uma vez,
    // veja o passo a passo no README.
    match /meta/adminBootstrap {
      allow read: if true;
      allow update: if isSignedIn()
        && onlyFields(['claimed'])
        && resource.data.claimed == false
        && request.resource.data.claimed == true;
      allow create, delete: if false;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // criação: só o próprio uid, só os 5 campos esperados, e só pode se
      // autodeclarar administrador se ainda não existe nenhum admin (bootstrap)
      allow create: if isOwner(uid)
        && onlyFields(['email', 'role', 'appSettings', 'activeVehicleId', 'createdAt'])
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.createdAt is number
        && (
          (
            get(/databases/$(database)/documents/meta/adminBootstrap).data.claimed == false
            && request.resource.data.role == 'administrador'
          ) ||
          request.resource.data.role == 'publico'
        );

      // atualização: comparamos o documento resultante inteiro contra o atual.
      // Dono: só pode mudar appSettings/activeVehicleId — email/role/createdAt
      // têm que continuar idênticos ao que já estava salvo.
      // Administrador: só pode mudar o campo role de qualquer usuário — todo
      // o resto do documento (inclusive appSettings de outra pessoa) tem que
      // permanecer inalterado.
      allow update: if
        (
          isOwner(uid)
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && request.resource.data.createdAt == resource.data.createdAt
        ) || (
          isAdmin()
          && request.resource.data.email == resource.data.email
          && request.resource.data.appSettings == resource.data.appSettings
          && request.resource.data.activeVehicleId == resource.data.activeVehicleId
          && request.resource.data.createdAt == resource.data.createdAt
          && (request.resource.data.role == 'publico' || request.resource.data.role == 'administrador')
        );

      allow delete: if false;

      match /vehicles/{vehicleId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && onlyFields([
               'name', 'type', 'config', 'currentOdometer',
               'fuelEntries', 'oilRecords', 'tireRecords'
             ]);
      }
    }

    // nega qualquer leitura/escrita fora dos caminhos definidos acima —
    // o Firestore já bloqueia por padrão o que não tem regra, mas deixamos
    // isso explícito para não depender de comportamento implícito.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
